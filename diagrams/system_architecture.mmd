        NS_API[RESTlet<br/>Endpoints]
        NS_LOGIC[Business Logic<br/>Scripts]
        NS_CONFIG[Configuration<br/>Records]

        NS_API --> NS_LOGIC
        NS_LOGIC --> NS_CONFIG
    end

    style ODOO fill:#e3f2fd
    style NETSUITE fill:#fff8e1
    style API fill:#c8e6c9
    style INTEG fill:#c8e6c9
