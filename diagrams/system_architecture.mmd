        direction TB
        POS[POS Frontend<br/>UI Layer] --> ORDER[POS Order Model<br/>Business Logic]
        ORDER --> INTEG[NetSuite Module<br/>Integration Layer]

        CONFIG[Configuration<br/>Model] -.-> INTEG
        LOGS[Sync Logging<br/>Model] -.-> INTEG

        INTEG --> API[API Client<br/>Service]
