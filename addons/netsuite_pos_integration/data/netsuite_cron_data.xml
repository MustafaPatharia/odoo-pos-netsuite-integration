<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ========================================== -->
        <!-- CRON 1: Hourly Product Sync from NetSuite -->
        <!-- ========================================== -->
        <record id="ir_cron_netsuite_product_sync" model="ir.cron">
            <field name="name">NetSuite: Fetch Products Hourly</field>
            <field name="model_id" ref="model_netsuite_product_sync"/>
            <field name="state">code</field>
            <field name="code">
config = env['netsuite.config'].search([('active', '=', True)], limit=1)
if config and config.config_hourly_sync_enabled:
    result = model.sync_products_from_netsuite(limit=100)
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>
        
        <!-- ========================================== -->
        <!-- CRON 2: Daily Consolidated Order Sync (Midnight) -->
        <!-- ========================================== -->
        <record id="ir_cron_netsuite_order_sync" model="ir.cron">
            <field name="name">NetSuite: Sync Consolidated Orders Daily</field>
            <field name="model_id" ref="model_netsuite_consolidated_sync"/>
            <field name="state">code</field>
            <field name="code">
config = env['netsuite.config'].search([('active', '=', True)], limit=1)
if config and config.config_integration_mode == 'scheduled':
    result = model.sync_consolidated_orders()
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=0, minute=5, second=0)"/>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>
        
        <!-- ========================================== -->
        <!-- CRON 3: Daily Consolidated Invoice Sync (Midnight) -->
        <!-- ========================================== -->
        <record id="ir_cron_netsuite_invoice_sync" model="ir.cron">
            <field name="name">NetSuite: Sync Consolidated Invoices Daily</field>
            <field name="model_id" ref="model_netsuite_consolidated_sync"/>
            <field name="state">code</field>
            <field name="code">
config = env['netsuite.config'].search([('active', '=', True)], limit=1)
if config and config.config_integration_mode == 'scheduled':
    result = model.sync_consolidated_invoices()
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=0, minute=10, second=0)"/>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>

    </data>
</odoo>

