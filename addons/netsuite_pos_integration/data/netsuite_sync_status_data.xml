<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Default Configuration -->
        <record id="default_netsuite_config" model="netsuite.config">
            <field name="name">NetSuite Integration</field>
            <field name="active" eval="True"/>
            <field name="api_url">http://mock-netsuite:3000/api</field>
            <field name="sync_mode">realtime</field>
            <field name="enable_manual_sync" eval="True"/>
            <field name="enable_auto_sync" eval="True"/>
            <field name="batch_size">50</field>
            <field name="batch_schedule_time">02:00</field>
            <field name="enable_retry" eval="True"/>
            <field name="max_retry_attempts">3</field>
            <field name="retry_delay_minutes">5</field>
            <field name="connection_timeout">30</field>
            <field name="request_timeout">60</field>
            <field name="enable_debug_logging" eval="False"/>
            <field name="log_payload" eval="True"/>
            <field name="sync_on_order_confirm" eval="True"/>
            <field name="sync_on_payment" eval="False"/>
        </record>

    </data>
</odoo>
