<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- NetSuite Configuration Form View -->
    <record id="view_netsuite_config_form" model="ir.ui.view">
        <field name="name">netsuite.config.form</field>
        <field name="model">netsuite.config</field>
        <field name="arch" type="xml">
            <form string="NetSuite Configuration">
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object" class="btn-primary"/>
                    <button name="action_view_sync_logs" string="View Sync Logs" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g., NetSuite Integration"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Credentials" name="credentials">
                            <group>
                                <group string="API Settings">
                                    <field name="api_url" placeholder="http://localhost:3000"/>
                                    <field name="account_id" placeholder="TSTDRV123456"/>
                                </group>
                                <group string="OAuth Credentials">
                                    <field name="consumer_key" password="True" placeholder="Consumer Key"/>
                                    <field name="consumer_secret" password="True" placeholder="Consumer Secret"/>
                                    <field name="token_id" password="True" placeholder="Token ID"/>
                                    <field name="token_secret" password="True" placeholder="Token Secret"/>
                                </group>
                            </group>
                        </page>

                        <page string="NetSuite Configuration" name="netsuite_config">
                            <field name="netsuite_config" invisible="1"/>
                            <group>
                                <field name="last_config_fetch" readonly="1"/>
                            </group>

                            <div class="alert alert-info" role="alert" invisible="netsuite_config">
                                <p><strong>No Configuration Loaded</strong></p>
                                <p>Configuration will be automatically received from NetSuite via POST API.</p>
                                <p>NetSuite will send updates to: <code>/api/netsuite/config/update</code></p>
                            </div>

                            <group invisible="not netsuite_config">
                                <group string="Integration Mode">
                                    <field name="config_integration_mode" readonly="1"/>
                                    <field name="config_manual_execution_enabled" readonly="1"/>
                                </group>

                                <group string="Retry Policy">
                                    <field name="config_retry_enabled" readonly="1"/>
                                    <field name="config_max_retries" readonly="1"/>
                                    <field name="config_retry_delay" readonly="1"/>
                                    <field name="config_use_exponential_backoff" readonly="1"/>
                                    <field name="config_backoff_multiplier" readonly="1"/>
                                </group>

                                <group string="Notifications">
                                    <field name="config_send_email_on_failure" readonly="1"/>
                                    <field name="config_send_email_on_success" readonly="1"/>
                                    <field name="config_notification_recipients" readonly="1" widget="text"/>
                                </group>

                                <group string="Logging &amp; Debugging">
                                    <field name="config_debug_logging" readonly="1"/>
                                    <field name="config_log_retention_days" readonly="1"/>
                                    <field name="config_log_request_payload" readonly="1"/>
                                    <field name="config_log_response_payload" readonly="1"/>
                                </group>

                                <group string="Consolidation Rules">
                                    <field name="config_consolidate_orders" readonly="1"/>
                                    <field name="config_consolidate_invoices" readonly="1"/>

                                </group>
                            </group>

                            <!-- Validation Warning: Real-time + Consolidation Conflict -->
                            <div class="alert alert-danger" role="alert"
                                    invisible="config_integration_mode != 'realtime' or (not config_consolidate_orders and not config_consolidate_invoices)">
                                <strong>⚠️ Configuration Error!</strong>
                                <p style="margin-top: 5px; margin-bottom: 0;">
                                    Real-Time mode does not support consolidation.
                                    Please update NetSuite configuration to disable consolidation flags or switch to Scheduled/Manual mode.
                                </p>
                            </div>

                            <!-- Info: Manual Button Behavior -->
                            <div class="alert alert-info" role="alert" style="margin-top: 10px;">
                                <strong>ℹ️ Manual Sync Buttons:</strong>
                                <ul style="margin-bottom: 0; padding-left: 20px;">
                                    <li><strong>Real-time mode:</strong> Manual buttons work as fallback (forced 1:1 sync)</li>
                                    <li><strong>Scheduled/Manual modes:</strong> Manual buttons respect consolidation flags above</li>
                                </ul>
                            </div>
                            <div class="alert alert-warning" role="alert" invisible="not netsuite_config">
                                <p><strong>Note:</strong> All these settings are controlled by NetSuite and cannot be changed from Odoo.</p>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- NetSuite Configuration Tree View -->
    <record id="view_netsuite_config_tree" model="ir.ui.view">
        <field name="name">netsuite.config.tree</field>
        <field name="model">netsuite.config</field>
        <field name="arch" type="xml">
            <tree string="NetSuite Configurations">
                <field name="name"/>
                <field name="active"/>
                <field name="api_url"/>
                <field name="last_config_fetch"/>
            </tree>
        </field>
    </record>

    <!-- NetSuite Configuration Action -->
    <record id="action_netsuite_config" model="ir.actions.act_window">
        <field name="name">NetSuite Configuration</field>
        <field name="res_model">netsuite.config</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure NetSuite Integration
            </p>
            <p>
                Set up connection credentials for NetSuite integration.
                All business logic and sync settings are controlled by NetSuite.
            </p>
        </field>
    </record>

</odoo>
