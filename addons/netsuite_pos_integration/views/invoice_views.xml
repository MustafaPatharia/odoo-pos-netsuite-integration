<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Invoice Form View Extension -->
    <record id="view_invoice_form_netsuite" model="ir.ui.view">
        <field name="name">account.move.form.netsuite</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Add NetSuite Sync Information group after other fields -->
            <xpath expr="//page[@name='other_info']" position="inside">
                <group name="netsuite_sync" string="NetSuite Sync Information"
                       invisible="move_type not in ['out_invoice', 'out_refund']">
                    <group>
                        <field name="netsuite_sync_status" widget="badge"
                               decoration-success="netsuite_sync_status == 'synced'"
                               decoration-warning="netsuite_sync_status == 'queued'"
                               decoration-danger="netsuite_sync_status == 'failed'"/>
                        <field name="netsuite_tran_id" readonly="1"/>
                        <field name="netsuite_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="netsuite_sync_date" readonly="1"/>
                        <field name="netsuite_sync_count" readonly="1"/>
                        <field name="netsuite_error" readonly="1" invisible="not netsuite_error"/>
                    </group>
                </group>
            </xpath>

            <!-- Add smart button to view sync logs -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        name="action_view_netsuite_sync_log"
                        type="object"
                        icon="fa-exchange"
                        invisible="move_type not in ['out_invoice', 'out_refund']">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">NetSuite</span>
                        <span class="o_stat_text">Sync Logs</span>
                    </div>
                </button>
            </xpath>

        </field>
    </record>

    <!-- Invoice Tree View Extension -->
    <record id="view_invoice_tree_netsuite" model="ir.ui.view">
        <field name="name">account.move.tree.netsuite</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="decoration-success">netsuite_sync_status == 'synced' and move_type in ['out_invoice', 'out_refund']</attribute>
                <attribute name="decoration-danger">netsuite_sync_status == 'failed' and move_type in ['out_invoice', 'out_refund']</attribute>
            </xpath>
            <xpath expr="//field[@name='state']" position="after">
                <field name="netsuite_sync_status" optional="show"
                       invisible="move_type not in ['out_invoice', 'out_refund']"/>
                <field name="netsuite_tran_id" optional="hide"
                       invisible="move_type not in ['out_invoice', 'out_refund']"/>
            </xpath>
        </field>
    </record>

    <!-- Invoice Search View Extension -->
    <record id="view_invoice_search_netsuite" model="ir.ui.view">
        <field name="name">account.move.search.netsuite</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <group expand="0" string="NetSuite Sync">
                    <filter name="netsuite_not_synced" string="Not Synced to NetSuite"
                            domain="[('netsuite_sync_status', '=', 'not_synced'), ('move_type', 'in', ['out_invoice', 'out_refund'])]"/>
                    <filter name="netsuite_synced" string="Synced to NetSuite"
                            domain="[('netsuite_sync_status', '=', 'synced'), ('move_type', 'in', ['out_invoice', 'out_refund'])]"/>
                    <filter name="netsuite_failed" string="NetSuite Sync Failed"
                            domain="[('netsuite_sync_status', '=', 'failed'), ('move_type', 'in', ['out_invoice', 'out_refund'])]"/>
                    <filter name="netsuite_queued" string="Queued for NetSuite"
                            domain="[('netsuite_sync_status', '=', 'queued'), ('move_type', 'in', ['out_invoice', 'out_refund'])]"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
