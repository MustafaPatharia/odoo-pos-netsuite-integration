              parent="menu_netsuite_operations"
              action="action_netsuite_eod_invoice_summary"
              sequence="30"/>

    <!-- ========================================== -->
    <!-- Sync Submenu -->
    <!-- ========================================== -->
    <menuitem id="menu_netsuite_sync"
              name="Sync"
              parent="menu_netsuite_root"
              sequence="30"/>

    <menuitem id="menu_netsuite_sync_queue"
              name="Queue"
              parent="menu_netsuite_sync"
              action="action_netsuite_sync_queue"
              sequence="10"/>

    <menuitem id="menu_netsuite_sync_log"
              name="Logs"
              parent="menu_netsuite_sync"
              action="action_netsuite_sync_log"
              sequence="20"/>

    <!-- ========================================== -->
    <!-- Reports Submenu (Future Scope) -->
    <!-- ========================================== -->
    <menuitem id="menu_netsuite_reports"
