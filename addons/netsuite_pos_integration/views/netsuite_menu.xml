<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================== -->
    <!-- Main NetSuite Menu -->
    <!-- ========================================== -->
    <menuitem id="menu_netsuite_root"
              name="NetSuite"
              sequence="100"
              web_icon="netsuite_pos_integration,static/description/icon.png"/>

    <!-- ========================================== -->
    <!-- Master Data Mappings Submenu -->
    <!-- ========================================== -->
    <menuitem id="menu_netsuite_configurations"
              name="Master Data Mappings"
              parent="menu_netsuite_root"
              sequence="10"/>

    <!-- <menuitem id="menu_netsuite_config"
              name="NetSuite Settings"
              parent="menu_netsuite_configurations"
              action="action_netsuite_config"
              sequence="10"/> -->

    <menuitem id="menu_netsuite_subsidiary_mapping"
              name="Subsidiary Mapping"
              parent="menu_netsuite_configurations"
              action="action_netsuite_subsidiary_mapping"
              sequence="20"/>

    <menuitem id="menu_netsuite_payment_method_mapping"
              name="Payment Method Mapping"
              parent="menu_netsuite_configurations"
              action="action_netsuite_payment_method_mapping"
              sequence="30"/>

    <!-- ========================================== -->
    <!-- Operations Submenu -->
    <!-- ========================================== -->
    <menuitem id="menu_netsuite_operations"
              name="Operations"
              parent="menu_netsuite_root"
              sequence="20"/>

    <menuitem id="menu_netsuite_fetch_products"
              name="Fetch Products"
              parent="menu_netsuite_operations"
