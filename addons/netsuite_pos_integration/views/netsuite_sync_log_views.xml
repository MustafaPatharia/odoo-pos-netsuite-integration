<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sync Log Form View -->
    <record id="view_netsuite_sync_log_form" model="ir.ui.view">
        <field name="name">netsuite.sync.log.form</field>
        <field name="model">netsuite.sync.log</field>
        <field name="arch" type="xml">
            <form string="Sync Log" create="false" edit="false">
                <header>
                    <button name="action_retry_sync" string="Retry Sync" type="object"
                            class="btn-primary" invisible="status == 'success'"/>
                    <button name="action_delete_log" string="Delete" type="object"
                            class="btn-secondary" confirm="Are you sure you want to delete this sync log?"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="reference" class="oe_edit_only"/>
                        <h1><field name="reference"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="config_id"/>
                            <field name="record_type"/>
                            <field name="model"/>
                            <field name="record_id"/>
                        </group>
                        <group>
                            <field name="operation"/>
                            <field name="sync_mode"/>
                            <field name="user_id"/>
                            <field name="create_date"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="request_url"/>
                            <field name="request_method"/>
                            <field name="response_code"/>
                        </group>
                        <group>
                            <field name="netsuite_id"/>
                            <field name="netsuite_tran_id"/>
                            <field name="execution_time_ms"/>
                            <field name="retry_count"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Request Payload" name="request">
                            <field name="request_payload" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                        <page string="Response Payload" name="response">
                            <field name="response_payload" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                        <page string="Error" name="error" invisible="not error_message">
                            <field name="error_message"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sync Log Tree View -->
    <record id="view_netsuite_sync_log_tree" model="ir.ui.view">
        <field name="name">netsuite.sync.log.tree</field>
        <field name="model">netsuite.sync.log</field>
        <field name="arch" type="xml">
            <tree string="Sync Logs" decoration-success="status == 'success'"
                  decoration-danger="status == 'failed'" decoration-warning="status == 'warning'"
                  create="false" multi_edit="1">
                <header>
                    <button name="action_delete_selected_logs" string="Delete Selected" type="object"
                            class="btn-danger" confirm="Are you sure you want to delete the selected sync logs?"/>
                </header>
                <field name="create_date"/>
                <field name="reference"/>
                <field name="record_type"/>
                <field name="operation"/>
                <field name="status"/>
                <field name="sync_mode"/>
                <field name="response_code"/>
                <field name="execution_time_ms" string="Time (ms)"/>
                <field name="netsuite_tran_id"/>
                <field name="user_id"/>
            </tree>
        </field>
    </record>

    <!-- Sync Log Search View -->
    <record id="view_netsuite_sync_log_search" model="ir.ui.view">
        <field name="name">netsuite.sync.log.search</field>
        <field name="model">netsuite.sync.log</field>
        <field name="arch" type="xml">
            <search string="Search Sync Logs">
                <field name="reference"/>
                <field name="record_type"/>
                <field name="netsuite_tran_id"/>
                <field name="netsuite_id"/>
                <filter name="success" string="Success" domain="[('status', '=', 'success')]"/>
                <filter name="failed" string="Failed" domain="[('status', '=', 'failed')]"/>
                <filter name="warning" string="Warning" domain="[('status', '=', 'warning')]"/>
                <separator/>
                <filter name="today" string="Today" domain="[('create_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
                <filter name="last_7_days" string="Last 7 Days" domain="[('create_date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="sales_order" string="Sales Orders" domain="[('record_type', '=', 'sales_order')]"/>
                <filter name="customer" string="Customers" domain="[('record_type', '=', 'customer')]"/>
                <filter name="payment" string="Payments" domain="[('record_type', '=', 'payment')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_type" string="Record Type" context="{'group_by': 'record_type'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Sync Log Action -->
    <record id="action_netsuite_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">netsuite.sync.log</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No sync logs found
            </p>
            <p>
                Sync logs are created automatically when sync operations are performed.
                They provide detailed audit trail of all NetSuite integration activities.
            </p>
        </field>
    </record>

</odoo>
